---
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import { HOME } from "@consts";
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <main class="space-y-10 py-8 text-slate-900 dark:text-slate-100">
      <section class="space-y-4">
        <h1 class="text-3xl font-semibold sm:text-4xl">
          HyeonGyu Lim
        </h1>
        <nav class="flex flex-wrap gap-3 text-sm text-slate-600 dark:text-slate-400">
          <a href="#about" class="hover:underline">About</a>
          <a href="#education" class="hover:underline">Education</a>
          <a href="#research" class="hover:underline">Research Interests</a>
          <a href="#projects" class="hover:underline">Projects</a>
          <a href="#cv" class="hover:underline">CV</a>
        </nav>
      </section>

      <section id="about" class="space-y-3 border-t border-slate-200 pt-8 dark:border-slate-700">
        <h2 class="text-xl font-semibold">About</h2>
        <p class="text-sm">Name: HyeonGyu Lim</p>
        <p class="text-sm">Major: Mechanical Engineering</p>
        <p class="text-sm">University: Hanyang University ERICA (2021-Present)</p>
        <p class="text-sm">
          Email: <a href="mailto:ctuuu06@hanyang.ac.kr" class="font-medium text-slate-900 hover:underline dark:text-slate-100">ctuuu06@hanyang.ac.kr</a>
        </p>
      </section>

      <section id="education" class="space-y-3 border-t border-slate-200 pt-8 dark:border-slate-700">
        <h2 class="text-xl font-semibold">Education</h2>
        <p class="text-sm">Hanyang University ERICA, Mechanical Engineering, 2021-Present</p>
      </section>

      <section id="research" class="space-y-3 border-t border-slate-200 pt-8 dark:border-slate-700">
        <h2 class="text-xl font-semibold">Research Interests</h2>
        <ul class="list-disc pl-5 text-slate-700 dark:text-slate-300 space-y-2">
          <li>[To be added]</li>
          <li>[To be added]</li>
          <li>[To be added]</li>
        </ul>
      </section>

      <section id="projects" class="space-y-3 border-t border-slate-200 pt-8 dark:border-slate-700">
        <h2 class="text-xl font-semibold">Projects</h2>
        <p class="text-sm">Project details will be updated here.</p>
      </section>

      <section id="cv" class="space-y-3 border-t border-slate-200 pt-8 dark:border-slate-700">
        <h2 class="text-xl font-semibold">Curriculum Vitae</h2>
        <p class="text-sm">CV will be available soon.</p>
      </section>

      <section class="space-y-3 border-t border-slate-200 pt-8 dark:border-slate-700">
        <h2 class="text-xl font-semibold">Planned Sections</h2>
        <ul class="list-disc pl-5 text-slate-700 dark:text-slate-300 space-y-2">
          <li>Publications [Coming soon]</li>
          <li>Awards & Scholarships [Coming soon]</li>
          <li>Additional academic materials [Coming soon]</li>
        </ul>
      </section>
    </main>
  </Container>
</PageLayout>
